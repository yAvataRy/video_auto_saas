{
  "name": "video-automation-saas",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nuxi dev",
    "build": "nuxi build",
    "start": "node .output/server/index.mjs",
    "preview": "nuxi preview",
    "generate": "nuxi generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxi typecheck",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky install"
  },
  "dependencies": {
    "@nuxt/ui": "^2.18.0",
    "@nuxtjs/supabase": "^2.0.4",
    "@pinia/nuxt": "^0.5.1",
    "@supabase/supabase-js": "^2.45.0",
    "cookie": "^1.1.1",
    "nuxt": "^4.4.2",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nuxt/devtools": "^1.7.0",
    "@nuxt/eslint-config": "^0.7.0",
    "@tailwindcss/forms": "^0.5.7",
    "@types/node": "^20.11.0",
    "@vitest/ui": "^1.3.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.2",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "vue-tsc": "^3.2.6"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "eslint"
    ],
